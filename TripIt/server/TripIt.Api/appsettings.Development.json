{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=db.YOUR_PROJECT;Port=5432;Database=postgres;Username=postgres;Password=<REPLACE_WITH_SUPABASE_PASSWORD>;SSL Mode=Require;Trust Server Certificate=true"
  },
